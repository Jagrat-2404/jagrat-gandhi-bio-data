---
interface Props {
  src: string;
  alt?: string;
}
const { src, alt = "Profile photo" } = Astro.props;
---

<aside class="bio-photo">
  <div class="bio-photo__wrapper">
    <img
      class="bio-photo__img"
      src={src}
      alt={alt}
      width="400"
      height="500"
      loading="eager"
    />
  </div>
</aside>

<style>
  .bio-photo {
    padding: var(--space-lg);
  }

  .bio-photo__wrapper {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 360px;
    aspect-ratio: 4 / 5;
    margin: 0 auto;
  }

  .bio-photo__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  @media (min-width: 768px) {
    .bio-photo {
      padding: var(--space-xl) var(--space-2xl);
      position: sticky;
      top: var(--space-lg);
    }

    .bio-photo__wrapper {
      margin: 0;
      max-width: 100%;
    }
  }
</style>
